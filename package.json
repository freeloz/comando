{
  "name": "@freeloz/comando",
  "version": "1.0.1",
  "description": "Generate shell scripts from the command line using AI providers",
  "main": "dist/index.js",
  "bin": {
    "comando": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "tsup",
    "typecheck": "tsc --noEmit",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "author": "ivanramirez-git",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeloz/comando.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "inquirer": "^8.2.5",
    "openai": "^4.24.1",
    "ora": "^5.4.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
